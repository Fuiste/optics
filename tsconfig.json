{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": false,
    "lib": ["ES2020"],
    "outDir": "dist",
    "sourceMap": true
  },
  "include": [
    "src/_internal.ts",
    "src/combinators.ts",
    "src/compose.ts",
    "src/fold.ts",
    "src/getter.ts",
    "src/index.ts",
    "src/iso.ts",
    "src/lens.ts",
    "src/prism.ts",
    "src/traversal.ts",
    "src/types.ts"
  ],
  "exclude": ["dist", "node_modules", "src/content/**", "src/pages/**", "src/layouts/**"]
}
